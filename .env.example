# ─── RazorGen Configuration ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# ── Anthropic API key ─────────────────────────────────────────────────────────
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Model ─────────────────────────────────────────────────────────────────────
# claude-sonnet-4-20250514  ← recommended (fast, accurate)
# claude-opus-4-5           ← slower, higher quality
# claude-haiku-4-5-20251001 ← fastest, lighter tasks
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: restrict which browser-selected models the server will forward.
# Leave as-is unless you want to allow a different list.
ANTHROPIC_ALLOWED_MODELS=claude-sonnet-4-20250514,claude-opus-4-5,claude-haiku-4-5-20251001

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=43000

# ── Users ─────────────────────────────────────────────────────────────────────
# Format: username:password,username2:password2
# Use strong passwords — these are the only thing protecting the app.
USERS=jason:changeme,colleague:changeme2

# ── IP allowlist (optional) ───────────────────────────────────────────────────
# Comma-separated list of IPs that are allowed to access the app.
# Leave blank to allow all IPs (rely on username/password only).
# Localhost is always allowed regardless.
# Example: ALLOWED_IPS=192.168.1.10,192.168.1.25
ALLOWED_IPS=

# Trust X-Forwarded-For only when RazorGen is behind a reverse proxy that
# overwrites that header (nginx, Caddy, Traefik, etc). Leave false otherwise.
TRUST_PROXY=false

# Optional: timeout for razor-runner preview execution in milliseconds.
# First run is slower (~5s) as .NET JITs the template. Subsequent runs are fast.
RAZOR_RUNNER_TIMEOUT_MS=20000
